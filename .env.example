# ==========================================
# HYPER-SPECIFIC MOOD & TROPE FINDER CONFIG
# ==========================================

# 1. Gemini API Key (Get from Google AI Studio: https://aistudio.google.com/)
GEMINI_API_KEY=your_gemini_api_key_here

# 2. MyAnimeList API Credentials (Get from MAL API Developer Portal: https://myanimelist.net/apiconfig)
MAL_CLIENT_ID=your_mal_client_id_here
MAL_CLIENT_SECRET=your_mal_client_secret_here

# 3. Web Server Port & Host Configuration
PORT=8000
HOST=127.0.0.1
