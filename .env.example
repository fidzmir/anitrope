# ==========================================
# HYPER-SPECIFIC MOOD & TROPE FINDER CONFIG
# ==========================================

# 1. Grok API Credentials
GROK_BASE_URL=https://api.rentalgenset.asia/v1
GROK_API_KEY=your_grok_api_key_here
GROK_MODEL=grok-4.5

# 2. Gemini API Key (Get from Google AI Studio: https://aistudio.google.com/)
GEMINI_API_KEY=your_gemini_api_key_here

# 3. MyAnimeList API Credentials (Get from MAL API Developer Portal: https://myanimelist.net/apiconfig)
MAL_CLIENT_ID=your_mal_client_id_here
MAL_CLIENT_SECRET=your_mal_client_secret_here

# 4. Web Server Port & Host Configuration
PORT=8000
HOST=127.0.0.1
